{
  "$schema": "https://critter-quest.dev/schemas/tasks-v1.json",
  "version": "1.0.0",
  "name": "English Quest — Task Library",
  "description": "Portable English-learning task collection for kids (ages 8-10). Three difficulty levels (easy/medium/hard) plus EN/PL vocabulary pairs. Designed for use in language-learning games.",
  "author": "tokage87",
  "license": "MIT",
  "language": {
    "source": "en",
    "target": "pl"
  },

  "schema": {
    "easy": {
      "type": "fill-in-the-blank",
      "description": "Fill the blank ___ in a sentence with the correct word from 4 options.",
      "fields": {
        "sentence": "Full sentence with ___ as the blank placeholder",
        "correct": "The correct word to fill the blank",
        "distractors": "Array of 3 wrong options (plausible but incorrect)"
      }
    },
    "medium": {
      "type": "sentence-ordering",
      "description": "Given a set of words (correct + distractors), arrange the correct ones into a valid sentence.",
      "fields": {
        "topic": "Short hint about what the sentence is about",
        "words": "Correct words in the canonical order",
        "distractors": "Extra words that must NOT be used",
        "alternatives": "Optional: array of valid alternative orderings"
      },
      "validation": "Accept any arrangement of words from `words` (no `distractors`), min 3 words. Full correct = all words used. Partial = some words missing."
    },
    "hard": {
      "type": "free-writing",
      "description": "Open-ended question with sentence starters and a word bank. Student writes an answer.",
      "fields": {
        "question": "The prompt/question (may cover multiple aspects of a topic)",
        "starters": "Clickable sentence starters that insert into the answer",
        "wordBank": "Suggested vocabulary words for the answer"
      },
      "validation": "Always accept (writing practice). Minimum 3 words."
    },
    "vocabulary": {
      "type": "translation-pair",
      "description": "English ↔ Polish word/phrase pair, used for matching games.",
      "fields": {
        "en": "English word or phrase",
        "pl": "Polish translation"
      }
    }
  },

